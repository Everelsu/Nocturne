            "others":       { "emoji": "🔗",                                 "color": "0xb3b3b3" }
        },

        "logging": {
            "file": { "path": "./logs", "enable": true },
            "level": { "discord": "INFO", "vocard": "INFO", "ipc_client": "INFO" },
            "max-history": 30
        },

        "timer_settings": {
            "bot_activity_update": 600,
            "inactive_player_cleanup": 600,
            "cache_cleanup": 43200
        },

        "cooldowns": {
            "connect": [2, 30],
            "playlist view": [1, 30]
        },

        "aliases": {
            "connect": ["join"],
            "leave": ["stop", "bye"],
            "play": ["p"],
            "view": ["v"]
        }
    },

