            "applemusic":   { "emoji": "<:applemusic:994844332374884413>",   "color": "0xE298C4" },
            "reddit":       { "emoji": "<:reddit:996007566863773717>",       "color": "0xFF5700" },
            "tiktok":       { "emoji": "<:tiktok:996007689798811698>",       "color": "0x74ECE9" },
            "yandexmusic":  { "emoji": "<:yandexmusic:1490046255181598751>", "color": "0xFF0000" },
