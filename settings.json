        "nodes": {
            "DEFAULT": {
                "host": "lavalink",
                "port": 2333,
                "password": "youshallnotpass",
                "secure": false,
                "identifier": "DEFAULT",
                "yt_ratelimit": {
                    "tokens": [],
                    "config": { "retry_time": 10800, "max_requests": 30 },
                    "strategy": "LoadBalance"
                }
            }
        },

        "default_search_platform": "youtube",
        "lyrics_platform": "lrclib",
        "genius_token": "",
        "default_max_queue": 1000,

        "playlist_settings": {
            "max_playlists": 5,
            "max_tracks_per_playlist": 500,
            "default_playlist_name": "Favourite"
        },

        "webpanel_url": "https://nocturne.su",

        "ipc_client": {
            "host": "vocard-dashboard",
            "port": 8080,
            "password": "changeme",
            "secure": false,
            "enable": true
        },

        "default_controller": {
            "embeds": {
                "active": {
                    "author": {
                        "name": "Music Controller | @@channel_name@@",
                        "icon_url": "@@bot_icon@@"
                    },
                    "description": "**Now Playing: [@@track_name@@](@@track_url@@)\n Requester: @@track_requester_mention@@ | DJ: @@dj@@**",
                    "footer": {
                        "text": "Queue Length: @@queue_length@@ | Duration: @@track_duration@@ | Volume: @@volume@@% {{loop_mode != 'Off' ?? | Repeat: @@loop_mode@@}}"
                    },
                    "image": "@@track_thumbnail@@",
                    "color": "@@track_color@@"
                },
                "inactive": {
                    "title": { "name": "There are no songs playing right now" },
                    "description": "",
                    "image": "https://i.imgur.com/dIFBwU7.png",
                    "color": "@@default_embed_color@@"
                }
            },
            "buttons": [
                {
                    "back":      { "emoji": "⏮️", "label": "@@t_player.buttons.back@@" },
                    "play-pause": {
                        "states": {
                            "pause":  { "emoji": "⏸️", "label": "@@t_player.buttons.pause@@" },
                            "resume": { "emoji": "▶️", "label": "@@t_player.buttons.resume@@" }
                        }
                    },
                    "skip":    { "emoji": "⏭️", "label": "@@t_player.buttons.skip@@" },
                    "stop":    { "emoji": "⏹️", "label": "@@t_player.buttons.leave@@", "style": "red" },
                    "add-fav": { "emoji": "❤️", "label": "" }
                },
                { "webpanel": { "emoji": "🌐", "label": "Web Panel" } },
                { "tracks": { "label": "@@t_player.dropdown.trackSelect@@", "max_options": 10 } }
            ]
        },

        "default_voice_status_template": "{{@@track_name@@ != 'None' ?? @@track_source_emoji@@ Now Playing: @@track_name@@ // Waiting for song requests}}",

        "sources_settings": {
            "youtube":      { "emoji": "<:youtube:826661982760992778>",      "color": "0xFF0000" },
            "youtubemusic": { "emoji": "<:youtube:826661982760992778>",      "color": "0xFF0000" },
