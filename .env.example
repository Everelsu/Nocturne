# ─────────────────────────────────────────────────────────────────────────────
# Nocturne — environment variables template
#
# LOCAL DEV:  cp .env.example .env  →  заполни значения  →  docker compose up
# RAILWAY:    переменные задаются через Railway dashboard для каждого сервиса
#
# ! Никогда не коммить .env — он в .gitignore !
# ─────────────────────────────────────────────────────────────────────────────


# ╔══════════════════════════════════════════════════════════════════════════════
# ║  БОТ  (сервис vocard / vocard2)
# ╚══════════════════════════════════════════════════════════════════════════════

# Какую секцию settings.json использовать (nocturne | nocturne2)
BOT_SECTION=nocturne

# Discord токен и ID приложения
TOKEN=
CLIENT_ID=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Локально:  mongodb://admin:admin@vocard-db:27017
# Railway:   скопируй из MongoDB плагина → ${{MongoDB.MONGO_URL}}
MONGODB_URL=mongodb://admin:admin@vocard-db:27017
MONGODB_NAME=Nocturne

# ── Lavalink — первый нод (nocturne) ─────────────────────────────────────────
# Переопределяет nodes[0] из settings.json
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ── Lavalink — второй нод (nocturne2, только для vocard2) ────────────────────
# Переопределяет nodes[1] из settings.json
LAVALINK2_HOST=lavalink2
LAVALINK2_PORT=2333
LAVALINK2_PASSWORD=youshallnotpass

# ── Dashboard IPC ─────────────────────────────────────────────────────────────
# IPC_PASSWORD должен совпадать с DASHBOARD_PASSWORD
IPC_HOST=vocard-dashboard
IPC_PORT=8080
IPC_PASSWORD=changeme
IPC_ENABLE=true

# URL веб-панели (отображается в кнопке "Web Panel" у плеера)
WEBPANEL_URL=https://your-dashboard.railway.app

# ── Опциональные сервисы бота ─────────────────────────────────────────────────
# Genius API — фолбэк для текстов песен (необязательно)
GENIUS_TOKEN=

# YouTube OAuth refresh-токены для обхода rate-limit
# Формат: JSON-массив строк, например: ["1//token1","1//token2"]
YOUTUBE_OAUTH_TOKENS=


# ╔══════════════════════════════════════════════════════════════════════════════
# ║  DASHBOARD  (сервис vocard-dashboard)
# ╚══════════════════════════════════════════════════════════════════════════════

HOST=0.0.0.0
PORT=8080

# Пароль IPC-сервера — должен совпадать с IPC_PASSWORD бота
DASHBOARD_PASSWORD=changeme

# Discord OAuth2 (https://discord.com/developers/applications)
CLIENT_ID=
CLIENT_SECRET_ID=

# Случайная строка для шифрования сессий (openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string

# Redirect URI из Discord Developer Portal
REDIRECT_URL=http://localhost:8080/callback


# ╔══════════════════════════════════════════════════════════════════════════════
# ║  LAVALINK  (сервисы lavalink / lavalink2)
# ╚══════════════════════════════════════════════════════════════════════════════

# Пароль Lavalink-сервера — должен совпадать с LAVALINK_PASSWORD бота
LAVALINK_SERVER_PASSWORD=youshallnotpass
SERVER_PORT=2333

# YouTube OAuth refresh-токен (один токен для Lavalink-плагина)
YOUTUBE_OAUTH_TOKEN=

# Яндекс Музыка
YANDEX_MUSIC_TOKEN=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# VK Music
VKMUSIC_USER_TOKEN=

# Spotify Tokener (внутренний сервис)
# Локально: http://spotify-tokener:49152/api/token
# Railway:  http://spotify-tokener.railway.internal:49152/api/token
SPOTIFY_TOKENER_URL=http://spotify-tokener:49152/api/token

# YouTube Cipher (внутренний сервис)
# Локально: http://yt-cipher:8001
# Railway:  http://yt-cipher.railway.internal:8001
YT_CIPHER_URL=http://yt-cipher:8001
YT_CIPHER_PASSWORD=

# Sentry (необязательно — мониторинг ошибок)
SENTRY_DSN=
SENTRY_ENV=production

# ── Apple Music (необязательно) ───────────────────────────────────────────────
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_API_TOKEN=
APPLE_MUSIC_KIT_KEY=
APPLE_MUSIC_TEAM_ID=

# ── Deezer (необязательно) ────────────────────────────────────────────────────
DEEZER_MASTER_KEY=


# ╔══════════════════════════════════════════════════════════════════════════════
# ║  MONGODB (локальный docker-compose — не нужно на Railway)
# ╚══════════════════════════════════════════════════════════════════════════════

MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=admin
