# ─────────────────────────────────────────────────────────────────────────────
# Nocturne — environment variables template
# Copy this file to .env (for vocard / nocturne instance) and fill in values.
# For the second bot instance copy to .env.nocturne2 and change the values.
#
# DO NOT commit .env to git — it's in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord bot ───────────────────────────────────────────────────────────────
TOKEN=
CLIENT_ID=
# BOT_SECTION is set per-service in docker-compose.yml / Railway
# BOT_SECTION=nocturne

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local compose: mongodb://admin:admin@vocard-db:27017
# Railway:       ${{MongoDB.MONGO_URL}}
MONGODB_URL=mongodb://admin:admin@vocard-db:27017
MONGODB_NAME=Nocturne

# ── Lavalink node (overrides settings.json nodes[0]) ─────────────────────────
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# Second node (overrides settings.json nodes[1], for vocard2 only)
LAVALINK2_HOST=lavalink2
LAVALINK2_PORT=2333
LAVALINK2_PASSWORD=youshallnotpass

# ── Dashboard IPC ─────────────────────────────────────────────────────────────
IPC_HOST=vocard-dashboard
IPC_PORT=8080
IPC_PASSWORD=changeme
IPC_ENABLE=true

WEBPANEL_URL=https://your-dashboard.railway.app

# ── Optional services ─────────────────────────────────────────────────────────
GENIUS_TOKEN=

# YouTube OAuth refresh token (comma-free JSON array for multiple tokens)
# Example: ["1//token1","1//token2"]
YOUTUBE_OAUTH_TOKENS=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Dashboard password must match IPC_PASSWORD above
DASHBOARD_PASSWORD=changeme
CLIENT_SECRET_ID=
SECRET_KEY=change-me-to-a-long-random-string
REDIRECT_URL=http://localhost:8080/callback

# ── Lavalink plugins ──────────────────────────────────────────────────────────
LAVALINK_SERVER_PASSWORD=youshallnotpass
YOUTUBE_OAUTH_TOKEN=
YANDEX_MUSIC_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
VKMUSIC_USER_TOKEN=

# ── MongoDB (local docker-compose only) ───────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=admin
